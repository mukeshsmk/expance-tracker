# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/construction_expense_db?retryWrites=true&w=majority

# File Uploads
MAX_FILE_SIZE_MB=10

# Vercel Blob (bill image uploads) — auto-populated by Vercel when a Blob
# store is connected to the project; only needed locally if you want to
# test uploads against a real store.
BLOB_READ_WRITE_TOKEN=

# CORS
CLIENT_URL=http://localhost:4200
